# Copy to .env and fill in. Load with: `set -a; source .env; set +a` before running,
# or use `python-dotenv` / your process manager.

# --- Postgres (direct connection, NOT PostgREST) ---
# Uses the same Supabase DB as the app. Port 6543 = transaction pooler (fine for
# this worker's short transactions). For many workers, consider 5432 (session pooler).
DATABASE_URL=postgresql://postgres.wcwaslfuvuboexuldtzy:!Bytes!0712@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?sslmode=require

# --- 3CX ---
THREECX_BASE_URL=https://bytesplatform.tx.3cx.us
THREECX_CLIENT_ID=sales
# The API key (client_secret) is read from system_settings.recording_access_token in the DB,
# so it is NOT set here.

# --- pyannote (required) ---
# 1) Create a token at https://hf.co/settings/tokens
# 2) Accept the license at https://hf.co/pyannote/speaker-diarization-3.1
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# --- faster-whisper ---
# small.en is a good accuracy/speed balance for accented phone audio.
# Use medium.en for higher accuracy if you have the CPU/GPU budget.
WHISPER_MODEL=small.en
WHISPER_DEVICE=cpu        # 'cuda' on a GPU box
WHISPER_COMPUTE=int8      # 'float16' with cuda

# --- worker tuning ---
WORKER_POLL_INTERVAL=5    # seconds between polls when idle
WORKER_MAX_ATTEMPTS=4     # give up after N failures (matches the claim query)
